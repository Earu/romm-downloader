# --- RomM (your existing/local RomM server) ---
# The app connects to RomM by logging in with your RomM username/password — it
# auto-provisions a client token, so no ROMM_TOKEN is needed. When set, this URL is
# PINNED: the login form's URL field is ignored (it's only honored on a fresh
# install with nothing configured). Recommended when exposing the app publicly, to
# prevent SSRF via the public login endpoint.
ROMM_URL=http://localhost:8080

# --- Auth: secret used to sign login session cookies. In the Docker image this is
#     auto-generated and persisted to /app/data/.auth_secret on first run; set it
#     here only to override (e.g. shared across replicas). Generate with
#     `openssl rand -hex 32`. Outside Docker, a dev fallback is used if unset. ---
AUTH_SECRET=

# --- Debrid provider (optional; without one, downloads use the built-in aria2
#     torrent client). Configurable in Settings too. ---
# Provider: none | torbox | realdebrid | alldebrid | premiumize
DEBRID_PROVIDER=
DEBRID_API_KEY=
# Files larger than this (GB) skip the debrid provider and offer the built-in
# torrent client instead. Default 30. Also editable in Settings.
MAX_DEBRID_GB=30

# --- Catalog metadata (IGDB via Twitch app: https://dev.twitch.tv/console/apps) ---
# Required for the browsable game catalog. Without it, catalog search is disabled.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Local app state ---
DATABASE_URL=file:./data/app.db
DOWNLOAD_TMP_DIR=./data/downloads

# --- Optional: share RomM's library on disk to group multi-file releases ---
# Path to RomM's ROMs directory (the one holding per-platform folders, usually
# <romm-library>/roms), mounted into this app. When set, a multi-file release
# (e.g. a Switch base game + update + DLC) is written into one per-game folder
# there and scanned, so RomM shows ONE library entry. Unset → each file uploads
# over HTTP as a separate entry (RomM's upload API can't create the folder).
ROMM_LIBRARY_PATH=
